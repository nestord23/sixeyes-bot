{
  "name": "sixeyes-bot",
  "version": "1.0.0",
  "description": "SixEyes — A modular Discord bot built with discord.js v14 and TypeScript",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "discord-bot",
    "sixeyes",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@googleapis/youtube": "^33.0.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.0.8",
    "youtube-dl-exec": "^3.1.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
